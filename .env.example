# Hindonix Environment Variables Template
# Copy this file to .env.local for development
# Copy this file to .env.production for Docker deployment

# ===========================================
# Hostinger MySQL Configuration (server-side)
# ===========================================
MYSQL_HOST=YOUR_HOSTINGER_MYSQL_HOST
MYSQL_PORT=3306
MYSQL_USER=YOUR_MYSQL_USER
MYSQL_PASSWORD=YOUR_MYSQL_PASSWORD
MYSQL_DATABASE=YOUR_MYSQL_DATABASE

# API server port (default: 3001)
API_PORT=3001
# CORS origin for API (use your domain in production, * for dev)
CORS_ORIGIN=*

NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dlt9vf8qk
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=ml_default

# ===========================================
# Clerk Authentication
# Get this from https://dashboard.clerk.com/
# ===========================================
VITE_CLERK_PUBLISHABLE_KEY="pk_test_ZW5nYWdpbmctaHllbmEtMTcuY2xlcmsuYWNjb3VudHMuZGV2JA"