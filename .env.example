# Hindonix Environment Variables Template
# Copy this file to .env.local for development
# Copy this file to .env.production for Docker deployment

# ===========================================
# Upstash Redis Configuration
# Get these from https://console.upstash.com/
# ===========================================
# Example: https://<your-upstash-host>.upstash.io
VITE_UPSTASH_REDIS_REST_URL="YOUR_UPSTASH_REDIS_REST_URL"
VITE_UPSTASH_REDIS_REST_TOKEN="YOUR_UPSTASH_REDIS_REST_TOKEN"


# ===========================================
# Cloudinary Configuration
# Get these from https://cloudinary.com/console
# ===========================================
VITE_CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
VITE_CLOUDINARY_UPLOAD_PRESET=YOUR_CLOUDINARY_UPLOAD_PRESET

# ===========================================
# Clerk Authentication
# Get this from https://dashboard.clerk.com/
# ===========================================
VITE_CLERK_PUBLISHABLE_KEY=YOUR_CLERK_PUBLISHABLE_KEY